# Environment variables (Sensitive data)
.env

# Unit test / coverage reports
.pytest_cache/
.tox/
.coverage
htmlcov/

# IDE-specific settings (Optional but recommended)
.vscode/
.idea/


# Logs and temporary files
logs/
*.log